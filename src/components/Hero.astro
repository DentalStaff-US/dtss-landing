---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
import hero from "../assets/hero-bg.jpg"
---

<section class="w-full px-4 py-20 text-center relative" aria-labelledby="hero-heading">
  <img class="absolute w-full top-0 z-10 pointer-events-none" src={hero.src}/>

<div class="max-w-6xl mx-auto relative z-20  text-center md:text-right flex flex-col md:items-end"> 
   <ScrollReveal client:load>
  <h1 id="hero-heading" class="text-5xl md:text-6xl font-bold mb-6 md:max-w-xl text-[#2a93d1]">
    It's a Whole New Staffing Experience
  </h1>
</ScrollReveal>
<ScrollReveal client:load delay={0.2}>
  <p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-2xl mx-auto">
    Dental Temps Staffing Solutions is a revolutionary dental staffing company. We have combined our proprietary software with a small town feel to let you know that we care.


  </p>
</ScrollReveal>
<ScrollReveal client:load delay={0.4}>
  <div class="flex flex-col sm:flex-row gap-4 justify-center">
    <a
      href="https://github.com/jonnysmillie/astro-base"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-8 py-3 bg-[#2a93d1] text-white rounded-lg hover:bg-[#2a7bd1] transition-colors font-medium text-xl"
      aria-label="Download Astro Base from GitHub (opens in new tab)"
    >

      <span>Learn More</span>
    </a>
  </div>
</ScrollReveal>

</div>

</section>
