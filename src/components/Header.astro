---
import { Icon } from "astro-icon/components";
import logo from "../assets/dtss-logo.png"

const clientSignInUrl = import.meta.env.PUBLIC_CLIENT_APP_URL ?? "#";
const professionalSignInUrl = import.meta.env.PUBLIC_PROFESSIONAL_APP_URL ?? "#";
---

<header
  class="w-full py-4 px-4  bg-[#2a93d1] sticky top-0 z-50 shadow-md"
  role="banner"
>
  <nav
    class="max-w-6xl mx-auto flex items-center justify-between"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="text-2xl font-bold text-gray-900 hover:text-gray-700 transition-colors"
      aria-label="Astro Base - Home"
    >
      <img src={logo.src} class="h-12 grayscale-100 brightness-1000"/>
    </a>
    
    <!-- Mobile menu button -->
    <button
      type="button"
      class="md:hidden p-2 text-white hover:text-gray-200 focus:outline-none focus:ring-2 focus:ring-black focus:ring-offset-2 rounded-lg"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="mobile-menu-button"
    >
      <Icon name="tabler:menu-2" class="w-6 h-6" aria-hidden="true" />
    </button>

    <!-- Desktop navigation -->
    <ul class="hidden md:flex items-center gap-6" role="list">
      <!-- <li>
        <a
          href="/#features"
          class="text-white hover:text-gray-300 transition-colors"
          aria-current={Astro.url.pathname === '/features' ? 'page' : undefined}
        >
          Features
        </a>
      </li> -->
      <li class="relative">
        <button
          type="button"
          id="member-login-button"
          class="flex items-center gap-1 text-white hover:text-gray-300 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#2a93d1] rounded"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="member-login-menu"
        >
          Member Login
          <Icon name="tabler:chevron-down" class="w-4 h-4" aria-hidden="true" />
        </button>
        <ul
          id="member-login-menu"
          class="hidden absolute right-0 mt-2 w-64 bg-white rounded-lg shadow-lg py-2 ring-1 ring-black/5"
          role="menu"
          aria-labelledby="member-login-button"
        >
          <li>
            <a
              href={professionalSignInUrl}
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900"
              role="menuitem"
            >
              Professional Member Portal
            </a>
          </li>
          <li>
            <a
              href={clientSignInUrl}
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900"
              role="menuitem"
            >
              Business Member Portal
            </a>
          </li>
        </ul>
      </li>
      <li>
        <a
          href="/#contact"
          class="px-4 py-2 bg-white text-[#2a93d1] rounded-lg hover:bg-gray-100 transition-colors"
          aria-current={Astro.url.pathname === '/contact' ? 'page' : undefined}
        >
          Contact
        </a>
      </li>
    </ul>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-200 bg-white"
    role="menu"
    aria-labelledby="mobile-menu-button"
  >
    <ul class="flex flex-col py-4" role="list">
      <!-- <li>
        <a
          href="/#features"
          class="block px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors"
          role="menuitem"
          aria-current={Astro.url.pathname === '/features' ? 'page' : undefined}
        >
          Features
        </a>
      </li> -->
      <li class="border-t border-gray-100 mt-2 pt-2">
        <p class="px-4 py-1 text-xs font-semibold text-gray-400 uppercase tracking-wide">
          Member Login
        </p>
      </li>
      <li>
        <a
          href={professionalSignInUrl}
          class="block px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors"
          role="menuitem"
        >
          Professional Member Portal
        </a>
      </li>
      <li>
        <a
          href={clientSignInUrl}
          class="block px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors"
          role="menuitem"
        >
          Business Member Portal
        </a>
      </li>
      <li class="border-t border-gray-100 mt-2 pt-2">
        <a
          href="/#contact"
          class="block px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors"
          role="menuitem"
          aria-current={Astro.url.pathname === '/contact' ? 'page' : undefined}
        >
          Contact
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu toggle functionality
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (menuButton && mobileMenu) {
    menuButton.addEventListener('click', () => {
      const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (
        !menuButton.contains(e.target as Node) &&
        !mobileMenu.contains(e.target as Node) &&
        !mobileMenu.classList.contains('hidden')
      ) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
      }
    });

    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
        menuButton.focus();
      }
    });
  }

  // Desktop "Member Login" dropdown toggle
  const memberButton = document.getElementById('member-login-button');
  const memberMenu = document.getElementById('member-login-menu');

  if (memberButton && memberMenu) {
    const closeMember = () => {
      memberButton.setAttribute('aria-expanded', 'false');
      memberMenu.classList.add('hidden');
    };

    memberButton.addEventListener('click', (e) => {
      e.stopPropagation();
      const isExpanded = memberButton.getAttribute('aria-expanded') === 'true';
      memberButton.setAttribute('aria-expanded', String(!isExpanded));
      memberMenu.classList.toggle('hidden');
    });

    document.addEventListener('click', (e) => {
      if (
        !memberButton.contains(e.target as Node) &&
        !memberMenu.contains(e.target as Node) &&
        !memberMenu.classList.contains('hidden')
      ) {
        closeMember();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !memberMenu.classList.contains('hidden')) {
        closeMember();
        memberButton.focus();
      }
    });
  }
</script>
