---
import { Icon } from "astro-icon/components";
import logo from "../assets/dtss-logo.png"

---

<footer
  id="contact"
  class="w-full py-12 px-4 text-white bg-[#2a93d1]"
  role="contentinfo"
>
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-8 mb-8 items-center">
      <div>
        <a
        href="/"
        class=""
        aria-label="Astro Base - Home"
      >
        <img src={logo.src} class="h-24 grayscale-100 brightness-1000"/>
      </a>
      </div>
      <div>
        <ul class="grid grid-cols-3 gap-4" role="list">
          <li>
            <a
              href="/privacy"
              class="hover:text-blue-200 transition-colors"
              >Privacy</a
            >
          </li>
          <li>
            <a
              href="/terms"
              class="hover:text-blue-200 transition-colors"
              >Terms</a
            >
          </li>
          <li>
            <a
              href="/#contact"
              class="hover:text-blue-200 transition-colors"
              >Contact</a
            >
          </li>
        </ul>
      </div>

    </div>
    <div class="pt-8 border-t border-gray-200 text-center">
      <p>&copy; {new Date().getFullYear()} Dental Temps Staffing Solutions. All rights reserved.</p>
    </div>
  </div>
</footer>
