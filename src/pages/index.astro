---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import CTA from "../components/CTA.astro";
import { SITE } from "../config/site.mjs";
import TestimonialCarousel from "../components/Testimonials";
import ContactFormSection from "../components/ContactFormSection.astro";
---

<Layout
  title={SITE.title}
  description="A minimal, modern starter template for building fast websites with Astro. Includes React, Tailwind CSS, Framer Motion, and more."
  canonicalURL={SITE.url}
>
  <main id="main-content" role="main">
    <Hero />
    <Features />
    <TestimonialCarousel client:load/>
    <ContactFormSection />
    <!-- <CTA /> -->
  </main>
</Layout>
